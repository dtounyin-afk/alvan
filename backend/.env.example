# ============================================================
# ModaAfrik Cameroun — Variables d'environnement
# Renommer ce fichier en .env et remplir les valeurs
# ============================================================

# Serveur
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://votre-domaine.com
BACKEND_URL=https://api.votre-domaine.com

# JWT
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire_ici
JWT_EXPIRES_IN=7d

# ── ORANGE MONEY CAMEROUN ──────────────────────────────────
# Obtenir sur: https://developer.orange.com
ORANGE_MONEY_TOKEN=client_id:client_secret_en_base64
ORANGE_MONEY_MERCHANT_KEY=votre_merchant_key

# ── MTN MOMO CAMEROUN ──────────────────────────────────────
# Obtenir sur: https://momodeveloper.mtn.com
MTN_MOMO_API_KEY=votre_api_key
MTN_MOMO_USER_ID=votre_user_id
MTN_MOMO_API_SECRET=votre_api_secret
MTN_MOMO_ENV=production

# ── CINETPAY ───────────────────────────────────────────────
# Obtenir sur: https://cinetpay.com/developers
CINETPAY_API_KEY=votre_api_key_cinetpay
CINETPAY_SITE_ID=votre_site_id_cinetpay

# ── FEDAPAY ────────────────────────────────────────────────
# Obtenir sur: https://fedapay.com/developers
FEDAPAY_SECRET_KEY=sk_live_votre_cle_secrete
FEDAPAY_ENV=production
